{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://snn-online.local/spec/topology.schema.json",
  "title": "TopologyIR",
  "description": "跨 snn_online、dynn 与 neuralsoup 共享的通用网络拓扑中间表示。它描述节点集合、边集合、端口和注解，不把协议绑定到某一种层级、二维网格或局部连接结构。",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "spec_version",
    "topology_id",
    "node_sets",
    "edge_sets"
  ],
  "properties": {
    "spec_version": {
      "type": "string",
      "pattern": "^v[0-9]+(\\.[0-9]+)*$",
      "description": "拓扑协议版本。"
    },
    "topology_id": {
      "type": "string",
      "description": "拓扑唯一标识。"
    },
    "name": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "node_sets": {
      "type": "array",
      "description": "节点集合。一个集合可以表示层、区域、神经核团、输入编码器、读出头或任意逻辑分组。",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "kind", "size"],
        "properties": {
          "id": {
            "type": "string"
          },
          "kind": {
            "type": "string",
            "description": "节点集合类型，例如 neuron_population、input_encoder、readout、modulator、external_state。"
          },
          "size": {
            "type": "integer",
            "minimum": 1,
            "description": "集合内节点数量。"
          },
          "node_type": {
            "type": "string",
            "description": "节点动力学类型，例如 lif、izh、rate、linear、custom。"
          },
          "state_schema": {
            "type": "object",
            "description": "节点状态字段定义，例如 v、u、trace、refractory、custom_state。"
          },
          "parameters": {
            "type": "object",
            "description": "节点参数或参数采样分布。"
          },
          "coordinate_space": {
            "type": "object",
            "description": "可选坐标系。用于表达 1D/2D/3D 网格、任意嵌入坐标、层级位置或前端布局；执行引擎不能假设它一定存在。"
          },
          "partitions": {
            "type": "array",
            "description": "集合内子分区。用于区域、塑性范围、兴奋/抑制分组或可视化分组。",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["id"],
              "properties": {
                "id": {
                  "type": "string"
                },
                "selector": {
                  "type": "object",
                  "description": "分区选择器，可由索引范围、索引列表、标签、坐标范围或外部引用表达。"
                },
                "tags": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  },
                  "uniqueItems": true
                }
              }
            }
          },
          "tags": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "uniqueItems": true
          },
          "metadata": {
            "type": "object",
            "description": "非执行语义的补充信息。"
          }
        }
      }
    },
    "edge_sets": {
      "type": "array",
      "description": "边集合。边可以显式给出，也可以通过规则生成；规则类型保持开放，以便表达局部、随机、稠密、卷积式、低秩、程序化等结构。",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "source", "target", "representation"],
        "properties": {
          "id": {
            "type": "string"
          },
          "source": {
            "type": "object",
            "additionalProperties": false,
            "required": ["node_set"],
            "properties": {
              "node_set": {
                "type": "string"
              },
              "selector": {
                "type": "object",
                "description": "可选源节点选择器。"
              }
            }
          },
          "target": {
            "type": "object",
            "additionalProperties": false,
            "required": ["node_set"],
            "properties": {
              "node_set": {
                "type": "string"
              },
              "selector": {
                "type": "object",
                "description": "可选目标节点选择器。"
              }
            }
          },
          "representation": {
            "type": "object",
            "additionalProperties": false,
            "required": ["kind"],
            "properties": {
              "kind": {
                "type": "string",
                "enum": [
                  "explicit",
                  "generated",
                  "dense",
                  "sparse_matrix",
                  "external_ref"
                ],
                "description": "边表示方式。generated 的具体规则由 rule 字段说明。"
              },
              "rule": {
                "type": "object",
                "description": "生成规则，例如 random_sparse、local_radius、knn、all_to_all、convolutional、custom。"
              },
              "storage": {
                "type": "string",
                "enum": ["edge_list", "adjacency_list", "csr", "csc", "coo", "dense", "auto"]
              },
              "path": {
                "type": "string",
                "description": "外部边表或矩阵文件路径。"
              }
            }
          },
          "edges": {
            "type": "array",
            "description": "显式边列表。仅在 representation.kind 为 explicit 或小规模编辑态时使用。",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["pre", "post"],
              "properties": {
                "pre": {
                  "type": "integer",
                  "minimum": 0
                },
                "post": {
                  "type": "integer",
                  "minimum": 0
                },
                "weight": {
                  "type": "number"
                },
                "delay": {
                  "type": "number",
                  "minimum": 0
                },
                "tags": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  },
                  "uniqueItems": true
                }
              }
            }
          },
          "edge_type": {
            "type": "string",
            "description": "边动力学类型，例如 synapse、gap_junction、modulatory、readout。"
          },
          "parameters": {
            "type": "object",
            "description": "边参数或参数采样分布，例如权重初始化、延迟、时间常数。"
          },
          "plasticity": {
            "type": "object",
            "description": "该边集合绑定的可塑性规则、标签和更新权限。"
          },
          "tags": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "uniqueItems": true
          },
          "metadata": {
            "type": "object"
          }
        }
      }
    },
    "ports": {
      "type": "array",
      "description": "输入、输出、调制和观测端口。端口只定义外部系统如何接入拓扑，不限定内部实现。",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "direction", "node_set"],
        "properties": {
          "id": {
            "type": "string"
          },
          "direction": {
            "type": "string",
            "enum": ["input", "output", "modulation", "probe"]
          },
          "node_set": {
            "type": "string"
          },
          "selector": {
            "type": "object"
          },
          "schema": {
            "type": "object",
            "description": "端口数据形状、编码、解码或语义字段。"
          }
        }
      }
    },
    "annotations": {
      "type": "array",
      "description": "面向编辑器、分析器或实验报告的非执行注解。",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["kind", "target"],
        "properties": {
          "kind": {
            "type": "string"
          },
          "target": {
            "type": "string"
          },
          "payload": {
            "type": "object"
          }
        }
      }
    },
    "metadata": {
      "type": "object",
      "description": "版本、来源、编辑器布局和补充说明。"
    }
  }
}

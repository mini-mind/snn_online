{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://snn-online.local/spec/experiment.schema.json",
  "title": "ExperimentSpec",
  "description": "跨 snn_online、dynn 与 neuralsoup 共享的实验定义协议。",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "spec_version",
    "experiment",
    "task",
    "model",
    "plasticity",
    "training",
    "runtime"
  ],
  "properties": {
    "spec_version": {
      "type": "string",
      "description": "协议版本号，用于后续兼容性管理。",
      "pattern": "^v[0-9]+(\\.[0-9]+)*$"
    },
    "experiment": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name", "seed"],
      "properties": {
        "id": {
          "type": "string",
          "description": "实验唯一标识。建议与 run 目录、报告和回放引用一致。"
        },
        "name": {
          "type": "string",
          "description": "实验名称。"
        },
        "description": {
          "type": "string",
          "description": "实验简介。"
        },
        "seed": {
          "type": "integer",
          "description": "全局随机种子。"
        },
        "tags": {
          "type": "array",
          "description": "实验标签，便于过滤和对照。",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        },
        "owner": {
          "type": "string",
          "description": "实验定义维护者或来源。"
        },
        "created_at": {
          "type": "string",
          "description": "实验定义创建时间，建议使用 RFC 3339 UTC 时间戳。"
        }
      }
    },
    "task": {
      "type": "object",
      "additionalProperties": false,
      "required": ["task_id", "env_name", "episode_horizon"],
      "properties": {
        "task_id": {
          "type": "string",
          "description": "任务模板标识，例如 point_robot_full、partial_goal_cue。"
        },
        "env_name": {
          "type": "string",
          "description": "环境实现名。"
        },
        "observation_mode": {
          "type": "string",
          "description": "观测模式。当前重点是 full 与 partial_goal_cue。"
        },
        "action_space": {
          "type": "object",
          "description": "动作空间定义。允许离散和连续两类。",
          "additionalProperties": false,
          "properties": {
            "kind": {
              "type": "string",
              "enum": ["discrete", "continuous"]
            },
            "n": {
              "type": "integer",
              "minimum": 1
            },
            "shape": {
              "type": "array",
              "items": {
                "type": "integer",
                "minimum": 1
              }
            }
          }
        },
        "reward_config": {
          "type": "object",
          "description": "任务奖励相关配置。具体字段由任务实现解释。"
        },
        "episode_horizon": {
          "type": "integer",
          "minimum": 1,
          "description": "单个 episode 的最大步数。"
        },
        "partial_observability": {
          "type": "object",
          "description": "部分可观测设置，例如 cue 时长。"
        },
        "curriculum": {
          "type": "object",
          "description": "课程学习或任务调度配置。"
        },
        "env_config": {
          "type": "object",
          "description": "环境原始参数表，供具体任务消费。"
        }
      }
    },
    "model": {
      "type": "object",
      "additionalProperties": false,
      "required": ["family", "neuron_type", "topology_ref"],
      "properties": {
        "family": {
          "type": "string",
          "description": "模型族标识，例如 rsnn_world_model_agent。"
        },
        "topology_ref": {
          "type": "string",
          "description": "引用的 TopologyIR 文件名、对象名或注册表键。"
        },
        "neuron_type": {
          "type": "string",
          "description": "主神经元类型，例如 lif、izh 或 mixed。"
        },
        "state_layout": {
          "type": "string",
          "description": "隐藏状态布局，当前重点是 depth_x_width_x_height。"
        },
        "readout_heads": {
          "type": "array",
          "description": "读出头定义，例如 value、world_model、policy、reconstruction。",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["name", "kind"],
            "properties": {
              "name": {
                "type": "string"
              },
              "kind": {
                "type": "string"
              },
              "output_dim": {
                "type": "integer",
                "minimum": 1
              },
              "config": {
                "type": "object"
              }
            }
          }
        },
        "intrinsics": {
          "type": "object",
          "description": "神经元内禀参数随机化与初始化配置。"
        }
      }
    },
    "plasticity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["rule_family", "plastic_targets"],
      "properties": {
        "rule_family": {
          "type": "string",
          "description": "学习规则族，例如 etlp、three_factor、prediction_modulated。"
        },
        "trace_config": {
          "type": "object",
          "description": "资格迹、前后突触痕迹和多时间尺度 trace 的配置。"
        },
        "modulation_sources": {
          "type": "array",
          "description": "调制信号来源，例如 reward、td_error、prediction_error、novelty。",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        },
        "plastic_targets": {
          "type": "array",
          "description": "允许更新的连接或模块范围。",
          "items": {
            "type": "string",
            "enum": [
              "input",
              "recurrent",
              "interlayer",
              "readout",
              "all"
            ]
          },
          "minItems": 1,
          "uniqueItems": true
        },
        "stability_controls": {
          "type": "object",
          "description": "稳定性控制，例如裁剪、weight decay、homeostasis、normalization。"
        },
        "learner_config": {
          "type": "object",
          "description": "具体 learner 的原始配置。"
        }
      }
    },
    "training": {
      "type": "object",
      "additionalProperties": false,
      "required": ["episodes"],
      "properties": {
        "episodes": {
          "type": "integer",
          "minimum": 1
        },
        "eval_schedule": {
          "type": "object",
          "description": "评测频率与评测轮数。"
        },
        "exploration": {
          "type": "object",
          "description": "探索策略配置，例如 epsilon-greedy。"
        },
        "checkpoint_policy": {
          "type": "object",
          "description": "checkpoint 保存频率和保留策略。"
        },
        "batching": {
          "type": "object",
          "description": "如果后端支持批量 episode 或批量环境，可在此定义。"
        },
        "optimizer_mode": {
          "type": "string",
          "description": "训练模式，例如 local_online、hybrid、offline_readout。"
        }
      }
    },
    "runtime": {
      "type": "object",
      "additionalProperties": false,
      "required": ["engine", "step_mode"],
      "properties": {
        "engine": {
          "type": "string",
          "description": "执行引擎名称，例如 dynn。"
        },
        "device": {
          "type": "string",
          "description": "目标设备，例如 cpu、cuda。"
        },
        "step_mode": {
          "type": "string",
          "enum": ["fixed_step", "event_driven", "event_sparse"],
          "description": "执行时间推进模式。"
        },
        "profiling": {
          "type": "object",
          "description": "运行 profiling 配置。"
        },
        "io": {
          "type": "object",
          "description": "运行时 I/O 配置，例如事件刷盘频率、日志等级。"
        }
      }
    },
    "extensions": {
      "type": "object",
      "description": "为仓库特定实验保留的扩展字段，不应污染核心协议。",
      "propertyNames": {
        "pattern": "^[a-zA-Z0-9_.-]+$"
      }
    }
  }
}
